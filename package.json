{
  "name": "replicore",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:setup-ui": "vite build --config setup-ui/vite.config.js",
    "dev:setup-ui": "REPLICORE_SETUP_PORT=37210 vite --config setup-ui/vite.config.js",
    "dev:setup": "REPLICORE_SETUP_PORT=37210 node bin/run-node.js --setup & sleep 1 && REPLICORE_SETUP_PORT=37210 vite --config setup-ui/vite.config.js",
    "start:setup": "node bin/run-node.js --setup",
    "test": "node test/run-suite.mjs",
    "test:reliability": "node test/reliability-churn.mjs",
    "start:bootstrap": "node bin/run-bootstrap.js",
    "start:node": "node bin/run-node.js",
    "snapshot": "node bin/snapshot.js"
  },
  "dependencies": {
    "base58-js": "^3.0.3",
    "corestore": "^7.10.1",
    "hash-wasm": "^4.12.0",
    "hyperbee": "^2.27.3",
    "hypercore": "^11.33.2",
    "hypercore-crypto": "^3.4.2",
    "hyperdht": "^6.32.0",
    "hyperswarm": "^4.17.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "semver": "^7.8.5",
    "svelte": "^5.56.3",
    "vite": "^8.0.16"
  }
}
